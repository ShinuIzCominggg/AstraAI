<Window x:Class="AstraCosmeris_.ExitConfirmWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Exit" Height="450" Width="750" WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent" Topmost="True">

    <Border Background="#FDF8E2" CornerRadius="30" BorderBrush="#FF4C4C" BorderThickness="5" Margin="20">
        <Grid Margin="30,10,10,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Image Source="/assets/mad/mad.png" Stretch="Uniform" 
                   VerticalAlignment="Center" HorizontalAlignment="Center" Height="420" Width="442" Grid.Column="1"/>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" VerticalAlignment="Center" Margin="0,0,20,0">
                    <TextBlock Text="CẬU ĐỊNH BỎ TỚ THẬT À?!" FontSize="36" FontWeight="Black" 
                               Foreground="#FF4C4C" TextWrapping="Wrap" Margin="0,0,0,10"/>
                    <TextBlock Text="Cậu còn cả đống công việc chưa làm xong, đống task chưa tick kìa! Tớ sẽ không để cậu đi dễ dàng thế đâu!" 
                               FontSize="18" Foreground="#555" TextWrapping="Wrap" LineHeight="24"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,0,40,20">
                    <Button Content="✨ Tớ lỡ tay (Ở lại với Astra)" Height="55" Background="#2F3273" 
                            Foreground="White" FontWeight="Bold" FontSize="20" Margin="0,0,0,15" 
                            Cursor="Hand" Click="BtnStay_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="15"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button Content="🏃 Thoát thật (Rời đi)" Height="45" Background="#FFCDD2" 
                            Foreground="#D32F2F" FontWeight="Bold" FontSize="16" 
                            BorderThickness="0" Cursor="Hand" Click="BtnExit_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="12"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>