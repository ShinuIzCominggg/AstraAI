<Window x:Class="AstraCosmeris_.PomodoroSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pomodoro Setup" Height="420" Width="380" WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent">

    <Border Background="#FDF8E2" CornerRadius="25" BorderBrush="#2F3273" BorderThickness="5" MouseLeftButtonDown="Border_MouseLeftButtonDown" RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
            <TransformGroup>
                <RotateTransform x:Name="ShakeRotation" Angle="0"/>
                <TranslateTransform x:Name="ShakeTranslation" X="0" Y="0"/>
            </TransformGroup>
        </Border.RenderTransform>

        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,25">
                <Image Source="/assets/pomodoro/tomato.png" Width="40" Height="40" Margin="0,0,10,0"/>
                <TextBlock Text="POMODORO" FontSize="32" FontWeight="Black" Foreground="#2F3273" VerticalAlignment="Center"/>
            </StackPanel>

            <Grid Width="280">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Làm việc" FontWeight="Bold" Foreground="#2F3273" HorizontalAlignment="Center" FontSize="14"/>
                    <Button x:Name="BtnWorkUp" Content="▲" Foreground="#2F3273" Background="Transparent" BorderThickness="0" FontSize="22" Click="BtnWorkUp_Click" Cursor="Hand"/>
                    <TextBox x:Name="TxtWork" Text="25" FontSize="32" FontWeight="Bold" Foreground="#2F3273" TextAlignment="Center" Background="Transparent" BorderThickness="0" IsReadOnly="True"/>
                    <Button x:Name="BtnWorkDown" Content="▼" Foreground="#2F3273" Background="Transparent" BorderThickness="0" FontSize="22" Click="BtnWorkDown_Click" Cursor="Hand"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Nghỉ ngơi" FontWeight="Bold" Foreground="#2F3273" HorizontalAlignment="Center" FontSize="14"/>
                    <Button x:Name="BtnBreakUp" Content="▲" Foreground="#2F3273" Background="Transparent" BorderThickness="0" FontSize="22" Click="BtnBreakUp_Click" Cursor="Hand"/>
                    <TextBox x:Name="TxtBreak" Text="5" FontSize="32" FontWeight="Bold" Foreground="#2F3273" TextAlignment="Center" Background="Transparent" BorderThickness="0" IsReadOnly="True"/>
                    <Button x:Name="BtnBreakDown" Content="▼" Foreground="#2F3273" Background="Transparent" BorderThickness="0" FontSize="22" Click="BtnBreakDown_Click" Cursor="Hand"/>
                </StackPanel>
            </Grid>

            <Button x:Name="BtnStart" Content="🚀 BẮT ĐẦU FOCUS" Background="#2F3273" Foreground="White" FontWeight="Bold" FontSize="18" Margin="0,25,0,0" Padding="25,12" Cursor="Hand" Click="BtnStart_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="15"/>
                    </Style>
                </Button.Resources>
            </Button>
            <Button Content="✖ Đóng" Background="Transparent" Foreground="#888" BorderThickness="0" Margin="0,15,0,0" Cursor="Hand" Click="BtnClose_Click"/>
        </StackPanel>
    </Border>
</Window>