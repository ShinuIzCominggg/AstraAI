<Window x:Class="AstraCosmeris_.OnboardingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Welcome to Astra" Height="450" Width="600"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen">

    <Border Background="#FDF8E2" CornerRadius="20" BorderBrush="#2F3273" BorderThickness="3" Margin="15" MouseLeftButtonDown="Window_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Opacity="0.3" ShadowDepth="5"/>
        </Border.Effect>

        <Grid Margin="20">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="450">
                <TextBlock Text="✨ CHÀO MỪNG CẬU ĐẾN VỚI ASTRA ✨" FontSize="22" FontWeight="Heavy" Foreground="#2F3273" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <TextBlock Text="Tớ là trợ lý ảo của cậu. Để tớ có thể suy nghĩ và nói chuyện, cậu hãy kết nối não bộ cho tớ nhé!" FontSize="14" Foreground="#555" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,25"/>

                <TextBlock Text="Chọn hệ thống Não bộ (Provider):" FontWeight="Bold" FontSize="14" Foreground="#2F3273" Margin="0,0,0,5"/>
                <Border Background="White" CornerRadius="10" BorderBrush="#9FB2D4" BorderThickness="2" Margin="0,0,0,15">
                    <ComboBox x:Name="CboProvider" FontSize="14" BorderThickness="0" Background="Transparent" Padding="5">
                        <ComboBoxItem Content="Groq (Nhanh, Miễn phí)"/>
                        <ComboBoxItem Content="OpenAI (Thông minh, Trả phí)"/>
                        <ComboBoxItem Content="Gemini (Google, Miễn phí)"/>
                    </ComboBox>
                </Border>

                <TextBlock Text="Nhập API Key của cậu:" FontWeight="Bold" FontSize="14" Foreground="#2F3273" Margin="0,0,0,5"/>
                <Border Background="White" CornerRadius="10" BorderBrush="#9FB2D4" BorderThickness="2" Margin="0,0,0,25">
                    <TextBox x:Name="TxtApiKey" FontSize="14" Padding="8" BorderThickness="0" Background="Transparent"/>
                </Border>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Content="🎁 Dùng thử Trial Key" Padding="10" Background="#FFCDD2" Foreground="#D32F2F" FontWeight="Bold" FontSize="14" BorderThickness="0" Cursor="Hand" Click="BtnTrial_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="10"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button Grid.Column="2" Content="🚀 BẮT ĐẦU THÔI!" Padding="10" Background="#2F3273" Foreground="White" FontWeight="Bold" FontSize="14" BorderThickness="0" Cursor="Hand" Click="BtnStart_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="10"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>

                <Button Content="✖ Thoát cài đặt" Background="Transparent" BorderThickness="0" Foreground="#888" Margin="0,15,0,0" Cursor="Hand" Click="BtnClose_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>