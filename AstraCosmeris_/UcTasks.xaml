<UserControl x:Class="AstraCosmeris_.UcTasks"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#FDF8E2" IsVisibleChanged="UserControl_IsVisibleChanged">
    <Grid Margin="25">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Margin="0,0,15,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Upcoming events&#x0a;this week" FontSize="32" FontWeight="Bold" 
                           Foreground="#2F3273" TextAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,30"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="Transparent" PanningMode="VerticalOnly">
                    <StackPanel x:Name="PanelUpcoming" Orientation="Vertical" Margin="0,0,10,0"/>
                </ScrollViewer>
            </Grid>
        </Border>

        <Border Grid.Column="1" Margin="15,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,30">
                    <TextBlock Text="Due Dates&#x0a;Urgent" FontSize="32" FontWeight="Bold" Foreground="#2F3273" TextAlignment="Center"/>

                    <TextBlock Text="★" FontSize="65" Foreground="#9FB2D4" VerticalAlignment="Center" Margin="15,-15,0,0"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="Transparent" PanningMode="VerticalOnly">
                    <StackPanel x:Name="PanelUrgent" Orientation="Vertical" Margin="0,0,10,0"/>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>