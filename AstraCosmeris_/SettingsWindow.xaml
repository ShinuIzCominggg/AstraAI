<Window x:Class="AstraCosmeris_.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Astra Settings" Height="600" Width="850"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="SidebarBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#2F3273"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="15,12"/>
            <Setter Property="Margin" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#DFE9F5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#FDF8E2" CornerRadius="20" BorderBrush="#2F3273" BorderThickness="3" Margin="10" MouseLeftButtonDown="Window_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Opacity="0.4" ShadowDepth="5"/>
        </Border.Effect>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#9FB2D4" CornerRadius="17,0,0,17">
                <StackPanel Margin="0,20,0,0">
                    <TextBlock Text="⚙️ CÀI ĐẶT" FontSize="22" FontWeight="Black" Foreground="#2F3273" Margin="20,0,0,30"/>
                    <Button x:Name="BtnTabApi" Content="🌐 Kết Nối AI" Style="{StaticResource SidebarBtn}" Click="MenuBtn_Click"/>
                    <Button x:Name="BtnTabPersona" Content="🎭 Tính Cách" Style="{StaticResource SidebarBtn}" Click="MenuBtn_Click"/>
                    <Button x:Name="BtnTabMemory" Content="🧠 Trí Nhớ" Style="{StaticResource SidebarBtn}" Click="MenuBtn_Click"/>
                    <Button x:Name="BtnTabNoti" Content="🔔 Thông Báo" Style="{StaticResource SidebarBtn}" Click="MenuBtn_Click"/>
                    <Button x:Name="BtnTabSystem" Content="💻 Hệ Thống" Style="{StaticResource SidebarBtn}" Click="MenuBtn_Click"/>
                </StackPanel>
            </Border>

            <Grid Grid.Column="1" Margin="25">
                <Button Content="✖" HorizontalAlignment="Right" VerticalAlignment="Top" FontSize="20" FontWeight="Bold" Foreground="#2F3273" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="BtnClose_Click"/>

                <StackPanel x:Name="TabApi" Visibility="Visible" Margin="0,40,0,0">
                    <TextBlock Text="Cấu hình Não bộ AI" FontSize="24" FontWeight="Bold" Foreground="#2F3273" Margin="0,0,0,20"/>

                    <TextBlock Text="Nhà cung cấp (Provider):" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="CboProvider" FontSize="15" Padding="5" SelectionChanged="CboProvider_SelectionChanged" Margin="0,0,0,15">
                        <ComboBoxItem Content="Groq"/>
                        <ComboBoxItem Content="OpenAI"/>
                        <ComboBoxItem Content="Gemini"/>
                        <ComboBoxItem Content="Claude"/>
                        <ComboBoxItem Content="Ollama"/>
                        <ComboBoxItem Content="OpenRouter"/>
                    </ComboBox>

                    <TextBlock Text="Mã Model (Tự do nhập):" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox x:Name="TxtModel" FontSize="15" Padding="8" Margin="0,0,0,15"/>

                    <TextBlock Text="API Key:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox x:Name="TxtApiKey" FontSize="15" Padding="8" Margin="0,0,0,15"/>
                </StackPanel>

                <StackPanel x:Name="TabPersona" Visibility="Collapsed" Margin="0,40,0,0">
                    <TextBlock Text="Lựa chọn Tính Cách" FontSize="24" FontWeight="Bold" Foreground="#2F3273" Margin="0,0,0,20"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <RadioButton x:Name="RadPresetPersona" Content="Dùng mẫu có sẵn" FontSize="16" FontWeight="Bold" Foreground="#2F3273" Margin="0,0,20,0" Checked="PersonaToggle_Checked"/>
                        <RadioButton x:Name="RadCustomPersona" Content="Tự định nghĩa" FontSize="16" FontWeight="Bold" Foreground="#2F3273" Checked="PersonaToggle_Checked"/>
                    </StackPanel>

                    <ComboBox x:Name="CboPersona" FontSize="16" Padding="10" SelectionChanged="CboPersona_SelectionChanged" Margin="0,0,0,10">
                        <ComboBoxItem Content="🌸 Dịu dàng, nhút nhát (Mặc định)"/>
                        <ComboBoxItem Content="🔥 Nghiêm khắc, kỷ luật"/>
                        <ComboBoxItem Content="💼 Nữ Chủ Tịch (Lạnh lùng)"/>
                        <ComboBoxItem Content="🤪 Hài hước, Gen Z"/>
                    </ComboBox>
                    <TextBlock x:Name="TxtPersonaDesc" Text="..." TextWrapping="Wrap" Margin="0,0,0,15" FontSize="14" Foreground="#555" LineHeight="22"/>

                    <TextBox x:Name="TxtCustomPersona" Visibility="Collapsed" Height="120" TextWrapping="Wrap" AcceptsReturn="True" FontSize="14" Padding="10" Margin="0,0,0,15" Background="#F0F4FA" BorderBrush="#9FB2D4" Text="Nhập System Prompt của cậu vào đây..."/>
                </StackPanel>

                <StackPanel x:Name="TabMemory" Visibility="Collapsed" Margin="0,40,0,0">
                    <TextBlock Text="Trí nhớ của Astra" FontSize="24" FontWeight="Bold" Foreground="#2F3273" Margin="0,0,0,20"/>
                    <TextBlock Text="Astra đang nhớ những điều này về cậu:" Margin="0,0,0,10"/>
                    <ListView x:Name="ListFacts" Height="300" BorderThickness="1" BorderBrush="#CCC" Background="White">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="5" Width="520">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding}" TextWrapping="Wrap" FontSize="14" VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" Content="🗑️" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="BtnDeleteFact_Click"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>

                <StackPanel x:Name="TabNoti" Visibility="Collapsed" Margin="0,40,0,0">
                    <TextBlock Text="Cài đặt Thông báo" FontSize="24" FontWeight="Bold" Foreground="#2F3273" Margin="0,0,0,20"/>
                    <CheckBox x:Name="ChkSound" Content="🔊 Bật âm thanh (Ting ting) khi có thông báo" FontSize="16" FontWeight="Bold" Margin="0,0,0,20"/>
                    <TextBlock Text="Thời gian hiển thị (giây):" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox x:Name="TxtDuration" FontSize="15" Padding="8" Width="100" HorizontalAlignment="Left" Margin="0,0,0,15"/>
                    <Button Content="Test Thông Báo" Width="150" HorizontalAlignment="Left" Padding="10" Background="#9FB2D4" FontWeight="Bold" Cursor="Hand" Click="BtnTestNoti_Click"/>
                </StackPanel>

                <StackPanel x:Name="TabSystem" Visibility="Collapsed" Margin="0,40,0,0">
                    <TextBlock Text="Quản lý Hệ thống" FontSize="24" FontWeight="Bold" Foreground="#2F3273" Margin="0,0,0,20"/>

                    <TextBlock Text="Vật lý Smol Astra (Ném văng):" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="CboPhysics" FontSize="15" Padding="5" Margin="0,0,0,20">
                        <ComboBoxItem Content="Cân bằng (Mặc định)"/>
                        <ComboBoxItem Content="Trơn trượt, nảy mạnh (Vui nhộn)"/>
                        <ComboBoxItem Content="Nặng nề, nhanh dừng (Nghiêm túc)"/>
                    </ComboBox>

                    <Button Content="🧹 Xóa lịch sử Chat" Padding="15" Margin="0,0,0,15" Background="#FFCDD2" Foreground="#D32F2F" FontWeight="Bold" Cursor="Hand" Click="BtnClearChat_Click"/>
                    <Button Content="⚠️ KHÔI PHỤC CÀI ĐẶT GỐC" Padding="15" Background="Red" Foreground="White" FontWeight="Bold" Cursor="Hand" Click="BtnFactoryReset_Click"/>
                </StackPanel>

                <Button Content="💾 LƯU CÀI ĐẶT" VerticalAlignment="Bottom" HorizontalAlignment="Right" Width="180" Height="45" Background="#2F3273" Foreground="White" FontSize="16" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnSave_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="22"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>