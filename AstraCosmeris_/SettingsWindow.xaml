<Window x:Class="AstraCosmeris_.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Astra Settings" Height="550" Width="750"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="CuteMenuBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#2F3273"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="15,12"/>
            <Setter Property="Margin" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#FDF8E2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#FDF8E2" CornerRadius="20" BorderBrush="#2F3273" BorderThickness="2" Margin="15" MouseLeftButtonDown="Window_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Opacity="0.25" ShadowDepth="4"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#9FB2D4" CornerRadius="18,0,0,18" Padding="10,30,10,10">
                <StackPanel>
                    <TextBlock Text="⚙️ CÀI ĐẶT" FontSize="22" FontWeight="Heavy" Foreground="#2F3273" HorizontalAlignment="Center" Margin="0,0,0,30"/>

                    <Button x:Name="BtnTabApi" Content="🔑 Kết nối (API)" Style="{StaticResource CuteMenuBtn}" Click="MenuBtn_Click"/>
                    <Button x:Name="BtnTabPrompt" Content="🧠 Tính cách" Style="{StaticResource CuteMenuBtn}" Click="MenuBtn_Click"/>
                    <Button x:Name="BtnTabMemory" Content="📚 Trí nhớ" Style="{StaticResource CuteMenuBtn}" Click="MenuBtn_Click"/>

                    <Border Height="2" Background="#FDF8E2" Margin="20,15" Opacity="0.5"/>

                    <Button x:Name="BtnTabSystem" Content="⚠️ Hệ thống" Style="{StaticResource CuteMenuBtn}" Foreground="#D32F2F" Click="MenuBtn_Click"/>
                </StackPanel>
            </Border>

            <Grid Grid.Column="1" Margin="25">
                <Button Content="✖" HorizontalAlignment="Right" VerticalAlignment="Top" Width="35" Height="35" Background="Transparent" BorderThickness="0" Foreground="#2F3273" FontSize="20" FontWeight="Bold" Cursor="Hand" Click="BtnClose_Click"/>

                <StackPanel x:Name="TabApi" Visibility="Visible" Margin="0,20,0,0">
                    <TextBlock Text="Cấu hình Trí tuệ Nhân tạo" FontSize="24" FontWeight="Bold" Foreground="#2F3273" Margin="0,0,0,25"/>

                    <TextBlock Text="Nhà cung cấp (Provider)" FontWeight="SemiBold" FontSize="15" Foreground="#2F3273" Margin="5,0,0,8"/>
                    <Border Background="White" CornerRadius="12" BorderBrush="#9FB2D4" BorderThickness="2" Padding="5" Margin="0,0,0,15">
                        <ComboBox x:Name="CboProvider" FontSize="15" BorderThickness="0" Background="Transparent" Padding="5" SelectionChanged="CboProvider_SelectionChanged">
                            <ComboBoxItem Content="Groq (Nhanh, Miễn phí)"/>
                            <ComboBoxItem Content="OpenAI (Thông minh, Trả phí)"/>
                            <ComboBoxItem Content="Gemini (Google, Miễn phí)"/>
                            <ComboBoxItem Content="Claude (Văn phong cảm xúc nhất)"/>
                            <ComboBoxItem Content="Ollama (Chạy Offline)"/>
                            <ComboBoxItem Content="OpenRouter (Trùm cuối, Đa Model)"/>
                        </ComboBox>
                    </Border>

                    <TextBlock Text="Chọn Model (Đề xuất năm 2026)" FontWeight="SemiBold" FontSize="15" Foreground="#2F3273" Margin="5,0,0,8"/>
                    <Border Background="White" CornerRadius="12" BorderBrush="#9FB2D4" BorderThickness="2" Padding="5" Margin="0,0,0,15">
                        <ComboBox x:Name="CboModel" FontSize="15" BorderThickness="0" Background="Transparent" Padding="5"/>
                    </Border>

                    <TextBlock Text="Hoặc nhập tên Model tùy chỉnh (Ghi đè)" FontWeight="SemiBold" FontSize="15" Foreground="#2F3273" Margin="5,0,0,8"/>
                    <Border Background="White" CornerRadius="12" BorderBrush="#9FB2D4" BorderThickness="2" Padding="5,2" Margin="0,0,0,15">
                        <TextBox x:Name="TxtModel" FontSize="15" Padding="5" BorderThickness="0" Background="Transparent"/>
                    </Border>
                    <TextBlock Text="*Để trống ô này nếu cậu muốn dùng Model đã chọn ở danh sách trên." FontSize="12" Foreground="#888" Margin="5,-10,0,15" FontStyle="Italic"/>

                    <TextBlock Text="API Key" FontWeight="SemiBold" FontSize="15" Foreground="#2F3273" Margin="5,0,0,8"/>
                    <Border Background="White" CornerRadius="12" BorderBrush="#9FB2D4" BorderThickness="2" Padding="5,2">
                        <TextBox x:Name="TxtApiKey" FontSize="15" Padding="5" BorderThickness="0" Background="Transparent"/>
                    </Border>
                </StackPanel>

                <StackPanel x:Name="TabPrompt" Visibility="Collapsed" Margin="0,20,0,0">
                    <TextBlock Text="Thiết lập Tính cách" FontSize="24" FontWeight="Bold" Foreground="#2F3273" Margin="0,0,0,10"/>
                    <TextBlock Text="Cậu muốn Astra là một người như thế nào? Hãy viết vào đây nha:" Margin="5,0,0,15" Foreground="#555" FontSize="14"/>

                    <Border Background="White" CornerRadius="15" BorderBrush="#9FB2D4" BorderThickness="2" Padding="5">
                        <TextBox x:Name="TxtPrompt" FontSize="14" Padding="8" BorderThickness="0" Background="Transparent" Height="260" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                    </Border>
                </StackPanel>

                <StackPanel x:Name="TabMemory" Visibility="Collapsed" Margin="0,20,0,0">
                    <TextBlock Text="Astra đang nhớ gì?" FontSize="24" FontWeight="Bold" Foreground="#2F3273" Margin="0,0,0,15"/>

                    <Border Background="White" CornerRadius="15" BorderBrush="#9FB2D4" BorderThickness="2" Padding="10">
                        <ListBox x:Name="ListFacts" Height="280" BorderThickness="0" Background="Transparent" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#E2E8F0" CornerRadius="10" Padding="12,8" Margin="0,5,0,5" Width="430">
                                        <TextBlock FontSize="14" TextWrapping="Wrap">
                                            <Run Text="{Binding Key}" FontWeight="Bold" Foreground="#2F3273"/>
                                            <Run Text=": " FontWeight="Bold" Foreground="#2F3273"/>
                                            <Run Text="{Binding Value}" Foreground="#333"/>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </StackPanel>

                <StackPanel x:Name="TabSystem" Visibility="Collapsed" Margin="0,20,0,0">
                    <TextBlock Text="Quản lý dữ liệu" FontSize="24" FontWeight="Bold" Foreground="#D32F2F" Margin="0,0,0,25"/>

                    <Button Content="🗑️ Xóa Lịch sử Chat" Padding="15" Background="#FFCDD2" BorderBrush="#D32F2F" BorderThickness="1" Foreground="#D32F2F" FontSize="15" FontWeight="Bold" Margin="0,0,0,20" Click="BtnClearChat_Click" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="12"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button Content="☢️ KHÔI PHỤC CÀI ĐẶT GỐC" Padding="15" Background="#D32F2F" BorderThickness="0" Foreground="White" FontSize="16" FontWeight="Bold" Click="BtnFactoryReset_Click" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="12"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <TextBlock Text="*Cảnh báo: Astra sẽ quên hết mọi thứ về cậu và trở lại như lúc mới tải về!" TextWrapping="Wrap" Foreground="#D32F2F" FontSize="13" Margin="5,15,0,0" FontStyle="Italic"/>
                </StackPanel>

                <Button x:Name="BtnSave" Content="💾 LƯU CÀI ĐẶT" VerticalAlignment="Bottom" HorizontalAlignment="Right" Width="180" Height="45" Foreground="White" FontSize="16" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnSave_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="22"/>
                        </Style>
                    </Button.Resources>
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#9d7eff" Offset="0.0"/>
                            <GradientStop Color="#6ecbff" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>