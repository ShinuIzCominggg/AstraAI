<Window x:Class="AstraCosmeris_.SpeechBubble"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SpeechBubble" 
        SizeToContent="WidthAndHeight" 
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False">

    <Grid Margin="10" MouseEnter="Grid_MouseEnter" MouseLeave="Grid_MouseLeave" 
          MouseLeftButtonDown="Grid_MouseLeftButtonDown"
          MinWidth="160" MinHeight="160">

        <Border Background="#F5FFFFFF" CornerRadius="20" BorderBrush="#606060" BorderThickness="1.5" Padding="15">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" Opacity="0.25" ShadowDepth="4"/>
            </Border.Effect>

            <StackPanel VerticalAlignment="Center">
                <StackPanel x:Name="MenuPanel" Orientation="Horizontal" HorizontalAlignment="Center" Visibility="Collapsed" Margin="0,0,0,10">
                    <Button x:Name="BtnPin" Content="📌 Pin" FontSize="11" Margin="0,0,8,0" Padding="6,3" Cursor="Hand" Click="BtnPin_Click" Background="#EEE" BorderBrush="#CCC"/>
                    <Button x:Name="BtnDetach" Content="🔗 Detach" FontSize="11" Padding="6,3" Cursor="Hand" Click="BtnDetach_Click" Background="#EEE" BorderBrush="#CCC"/>
                </StackPanel>

                <TextBlock x:Name="MessageText" Text="Lảm nhảm gì đó ở đây..." 
                           TextWrapping="Wrap" MaxWidth="280" FontSize="15" 
                           HorizontalAlignment="Center" TextAlignment="Center"
                           FontFamily="Segoe UI Semibold" Foreground="#333"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>