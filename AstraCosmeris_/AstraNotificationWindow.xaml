<Window x:Class="AstraCosmeris_.AstraNotificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Notification" Height="140" Width="360"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" Loaded="Window_Loaded">

    <Border Background="#FDF8E2" CornerRadius="15" BorderBrush="#2F3273" BorderThickness="3" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Opacity="0.3" ShadowDepth="5" Color="#2F3273"/>
        </Border.Effect>
        <Grid Margin="15,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="TxtTitle" Grid.Row="0" Text="🔔 Thông báo" FontWeight="Black" FontSize="16" Foreground="#2F3273"/>
            <TextBlock x:Name="TxtMessage" Grid.Row="1" Text="Nội dung..." TextWrapping="Wrap" FontSize="14" Foreground="#333" Margin="0,5,0,5"/>

            <StackPanel x:Name="ActionPanel" Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Visibility="Collapsed">
                <Button x:Name="BtnAction1" Content="Hành động 1" Margin="0,0,10,0" Padding="10,5" Background="#9FB2D4" Foreground="#2F3273" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnAction1_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <Button x:Name="BtnAction2" Content="Hành động 2" Padding="10,5" Background="#2F3273" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnAction2_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>