<Window x:Class="AstraCosmeris_.ChatHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Astra Chat" Height="500" Width="500"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" Topmost="True">

    <Window.Resources>
        <Style x:Key="SmoothThumb" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="#9FB2D4" CornerRadius="4" Margin="2,0,2,0"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="10"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Border Background="#E2E8F0" CornerRadius="5" Margin="0,2,0,2" Opacity="0.3"/>
                            <Track x:Name="PART_Track" IsDirectionReversed="true">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource SmoothThumb}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#FDF8E2" CornerRadius="15" BorderBrush="#2F3273" BorderThickness="3" Margin="10" MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Opacity="0.4" ShadowDepth="5"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="#2F3273" Margin="0,0,0,5">
                <TextBlock Text="💬 Lịch sử trò chuyện" Foreground="White" FontSize="18" FontWeight="Bold" Margin="15,10" VerticalAlignment="Center"/>
                <Button Content="✖" HorizontalAlignment="Right" Width="40" Background="Transparent" BorderThickness="0" Foreground="White" FontSize="20" Cursor="Hand" Click="BtnClose_Click"/>
            </Grid>

            <ScrollViewer x:Name="ChatScroll" Grid.Row="1" Margin="10" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="ChatList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="12" Padding="12,8" Margin="5,5,5,10" MaxWidth="320">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#9FB2D4"/>
                                        <Setter Property="HorizontalAlignment" Value="Left"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding [role]}" Value="user">
                                                <Setter Property="Background" Value="#E2E8F0"/>
                                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                                <Setter Property="BorderBrush" Value="#2F3273"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding [content]}" TextWrapping="Wrap" FontSize="15" Foreground="#333"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Border Grid.Row="2" Background="White" CornerRadius="15" Margin="10" Padding="5" BorderBrush="#D0D0D0" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="InputBox" Grid.Column="0" 
                             Background="Transparent" BorderThickness="0" 
                             FontSize="15" FontFamily="Segoe UI" VerticalAlignment="Center"
                             Padding="10,5" MinHeight="30" TextWrapping="Wrap" MaxHeight="80"
                             KeyDown="InputBox_KeyDown"/>

                    <Button x:Name="BtnSend" Grid.Column="1" Content="➤" 
                            Width="36" Height="36" Margin="5,0,0,0"
                            FontSize="18" Foreground="White" Cursor="Hand"
                            BorderThickness="0" Click="BtnSend_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="18"/>
                            </Style>
                        </Button.Resources>
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#9d7eff" Offset="0.0"/>
                                <GradientStop Color="#6ecbff" Offset="1.0"/>
                            </LinearGradientBrush>
                        </Button.Background>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>