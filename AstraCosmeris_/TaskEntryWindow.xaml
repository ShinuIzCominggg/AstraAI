<Window x:Class="AstraCosmeris_.TaskEntryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Task Entry" Height="400" Width="350"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" Topmost="True">

    <Border Background="#FDF8E2" CornerRadius="15" BorderBrush="#2F3273" BorderThickness="3" Margin="10" MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Opacity="0.4" ShadowDepth="5"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="#2F3273" Margin="0,0,0,10">
                <TextBlock x:Name="TxtTitle" Text="Lịch trình ngày: --/--/----" Foreground="White" FontSize="18" FontWeight="Bold" Margin="15,10" VerticalAlignment="Center"/>
                <Button Content="✖" HorizontalAlignment="Right" Width="40" Background="Transparent" BorderThickness="0" Foreground="White" FontSize="20" Cursor="Hand" Click="BtnClose_Click"/>
            </Grid>

            <TextBox x:Name="TxtTasks" Grid.Row="1" Margin="15,0,15,10" AcceptsReturn="True" TextWrapping="Wrap" 
                     FontSize="16" Background="Transparent" BorderThickness="0" Foreground="#333"
                     VerticalScrollBarVisibility="Auto" FontFamily="Segoe UI"/>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="15,0,15,15">
                <TextBlock x:Name="TxtStatus" Text="" Foreground="#2F3273" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="14" FontWeight="Bold"/>
                <Button Content="💾 Lưu Lịch Trình" FontSize="16" FontWeight="Bold" Background="#9FB2D4" Foreground="#2F3273" Padding="15,8" BorderThickness="0" Cursor="Hand" Click="BtnSave_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>