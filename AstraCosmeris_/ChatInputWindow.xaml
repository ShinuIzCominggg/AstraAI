<Window x:Class="AstraCosmeris_.ChatInputWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Astra Command Palette" Width="650" SizeToContent="Height"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <Style x:Key="SpotlightThumb" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="#9FB2D4" CornerRadius="3" Margin="1,0,1,0"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="7"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Border Background="#E2E8F0" CornerRadius="3.5" Opacity="0.3"/>
                            <Track x:Name="PART_Track" IsDirectionReversed="true">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource SpotlightThumb}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PaletteListBoxItem" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="4,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="10" SnapsToDevicePixels="true">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="true">
                                <Setter TargetName="Bd" Property="Background" Value="#9FB2D4"/>
                                <Setter Property="Foreground" Value="#2F3273"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="Bd" Property="Background" Value="#DFE9F5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#FDF8E2" CornerRadius="18" BorderBrush="#2F3273" BorderThickness="3" Margin="15">
        <Border.Effect>
            <DropShadowEffect BlurRadius="25" Opacity="0.4" ShadowDepth="6" Color="#2F3273"/>
        </Border.Effect>

        <Grid Grid.IsSharedSizeScope="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="18,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="🔍" FontSize="22" VerticalAlignment="Center" Margin="5,0,12,0"/>

                <TextBox x:Name="InputBox" Grid.Column="1" 
                         Background="Transparent" BorderThickness="0" 
                         FontSize="18" FontFamily="Segoe UI Semibold" Foreground="#2F3273"
                         VerticalAlignment="Center" CaretBrush="#2F3273"
                         Padding="0,5" TextWrapping="Wrap" MaxHeight="100"
                         TextChanged="InputBox_TextChanged"
                         PreviewKeyDown="InputBox_PreviewKeyDown"/>

                <TextBlock Grid.Column="1" x:Name="TxtPlaceholder" Text="Gõ lệnh (/), thêm nhanh (+), hoặc chat với Astra..." 
                           FontSize="18" FontFamily="Segoe UI" Foreground="#882F3273" 
                           VerticalAlignment="Center" IsHitTestVisible="False" Margin="2,5,0,5"
                           Visibility="Visible"/>
            </Grid>

            <ListBox x:Name="LstSuggestions" Grid.Row="1" 
                     Background="White" BorderThickness="0,1,0,0" BorderBrush="#DFE9F5"
                     MaxHeight="300" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ItemContainerStyle="{StaticResource PaletteListBoxItem}"
                     Visibility="Collapsed" Margin="0,0,0,10"
                     MouseDoubleClick="LstSuggestions_MouseDoubleClick">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Width="580" Margin="5,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Icon}" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Text="{Binding Title}" FontSize="15" FontWeight="Bold" Foreground="#2F3273"/>
                                <TextBlock Text="{Binding Description}" FontSize="12" Foreground="#666" Margin="0,3,0,0"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Border>
</Window>