<UserControl x:Class="AstraCosmeris_.UcCanvas"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">
    <Grid>
        <InkCanvas x:Name="DrawCanvas" Background="#FAFAFA" EditingMode="Ink"/>

        <Border VerticalAlignment="Bottom" HorizontalAlignment="Center" Background="#2F3273" CornerRadius="15" Padding="15,10" Margin="0,0,0,20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" Opacity="0.5" ShadowDepth="4"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal">
                <Button Content="🖊️ Bút" Width="70" Background="Transparent" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnPen_Click"/>
                <Button Content="🧽 Tẩy" Width="70" Background="Transparent" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnEraser_Click"/>

                <Rectangle Width="2" Fill="White" Opacity="0.3" Margin="10,0"/>
                <Button Width="30" Height="30" Background="Black" Margin="5,0" Cursor="Hand" Click="BtnColor_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="15"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <Button Width="30" Height="30" Background="#D32F2F" Margin="5,0" Cursor="Hand" Click="BtnColor_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="15"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <Button Width="30" Height="30" Background="#1976D2" Margin="5,0" Cursor="Hand" Click="BtnColor_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="15"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Rectangle Width="2" Fill="White" Opacity="0.3" Margin="10,0"/>
                <Button x:Name="BtnSettings" Content="⚙️" Width="50" Background="Transparent" Foreground="White" FontSize="20" BorderThickness="0" Cursor="Hand" Click="BtnSettings_Click">
                    <Button.ContextMenu>
                        <ContextMenu x:Name="CanvasMenu">
                            <MenuItem Header="🗂️ Ẩn/Hiện Thanh Bên" Click="MenuToggleSidebar_Click"/>
                            <MenuItem Header="🖥️ Toàn Màn Hình" Click="MenuFullScreen_Click"/>
                            <Separator/>
                            <MenuItem Header="🧹 Xóa sạch bảng" Click="MenuClear_Click" Foreground="Red"/>
                            <MenuItem Header="💾 Xuất ảnh PNG" Click="MenuExport_Click" FontWeight="Bold"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>