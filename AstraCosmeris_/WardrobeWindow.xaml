<Window x:Class="AstraCosmeris_.WardrobeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Phòng Thay Đồ Astra" Height="500" Width="750"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Width" Value="8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid x:Name="Bg" Background="Transparent">
                            <Border x:Name="TrackBackground" Background="Transparent" />
                            <Track x:Name="PART_Track" IsDirectionReversed="true">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="{x:Type Thumb}">
                                                <Border Background="#B0BEC5" CornerRadius="4" Margin="2,0,2,0" x:Name="ThumbBorder"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ThumbBorder" Property="Background" Value="#78909C" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OutfitCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="15"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="1.05" Duration="0:0:0.15" />
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="1.05" Duration="0:0:0.15" />
                            <ColorAnimation Storyboard.TargetProperty="BorderBrush.Color" To="#9FB2D4" Duration="0:0:0.15" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="1" Duration="0:0:0.15" />
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="1" Duration="0:0:0.15" />
                            <ColorAnimation Storyboard.TargetProperty="BorderBrush.Color" To="#E2E8F0" Duration="0:0:0.15" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StateBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="Foreground" Value="#2F3273"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#DFE9F5"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="#FDF8E2" CornerRadius="20" BorderBrush="#2F3273" BorderThickness="3" Margin="15" MouseLeftButtonDown="Window_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect BlurRadius="25" Opacity="0.35" ShadowDepth="6" Color="#2F3273"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1.5*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#F1F5F9" CornerRadius="17,0,0,17" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" x:Name="PreviewContainer" Background="White" CornerRadius="15" ClipToBounds="True" Margin="0,0,0,10">
                        <Grid>
                            <Border Background="#FAFAFA" CornerRadius="15"/>
                            <Ellipse Width="160" Height="25" Fill="#E2E8F0" VerticalAlignment="Bottom" Margin="0,0,0,15"/>
                            <Image x:Name="PreviewImage" Stretch="Uniform" Margin="10"/>

                            <Grid x:Name="Curtain" Height="0" VerticalAlignment="Top">
                                <Rectangle>
                                    <Rectangle.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0" SpreadMethod="Reflect">
                                            <GradientStop Color="#FF4757" Offset="0"/>
                                            <GradientStop Color="#FF6B81" Offset="0.1"/>
                                            <GradientStop Color="#FF4757" Offset="0.2"/>
                                        </LinearGradientBrush>
                                    </Rectangle.Fill>
                                </Rectangle>
                                <Border BorderBrush="#C0392B" BorderThickness="0,0,0,6" VerticalAlignment="Bottom"/>
                                <Grid.Effect>
                                    <DropShadowEffect BlurRadius="15" Opacity="0.4" ShadowDepth="8" Direction="270" Color="Black"/>
                                </Grid.Effect>
                            </Grid>
                        </Grid>
                    </Border>

                    <WrapPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,0,0,15">
                        <Button Style="{StaticResource StateBtnStyle}" Content="Idle" Tag="idle" Click="StateBtn_Click"/>
                        <Button Style="{StaticResource StateBtnStyle}" Content="Happy" Tag="happy" Click="StateBtn_Click"/>
                        <Button Style="{StaticResource StateBtnStyle}" Content="Mad" Tag="mad" Click="StateBtn_Click"/>
                        <Button Style="{StaticResource StateBtnStyle}" Content="Sitting" Tag="sitting" Click="StateBtn_Click"/>
                        <Button Style="{StaticResource StateBtnStyle}" Content="Thinking" Tag="thinking" Click="StateBtn_Click"/>
                        <Button Style="{StaticResource StateBtnStyle}" Content="Working" Tag="working" Click="StateBtn_Click"/>
                    </WrapPanel>

                    <Button Grid.Row="2" Content="✨ LƯU VÀ MẶC BỘ NÀY ✨" Background="#2F3273" Foreground="White" FontWeight="Heavy" FontSize="14" Padding="10" BorderThickness="0" Cursor="Hand" Click="BtnEquip_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="12">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <Grid Grid.Column="1" Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,15">
                    <TextBlock Text="👗 BỘ SƯU TẬP" FontSize="24" FontWeight="Heavy" Foreground="#2F3273" HorizontalAlignment="Left"/>
                    <Button Content="✖ Đóng" Background="Transparent" BorderThickness="0" Foreground="#D32F2F" FontWeight="Bold" FontSize="14" HorizontalAlignment="Right" VerticalAlignment="Center" Cursor="Hand" Click="BtnClose_Click"/>
                </Grid>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <WrapPanel HorizontalAlignment="Left">
                        <Border Style="{StaticResource OutfitCardStyle}" Width="110" Height="130" Margin="10" Tag="Default" MouseLeftButtonUp="OutfitCard_Click">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="👤" FontSize="35" HorizontalAlignment="Center"/>
                                <TextBlock Text="Mặc định" FontSize="14" FontWeight="Bold" Foreground="#2F3273" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource OutfitCardStyle}" Width="110" Height="130" Margin="10" Tag="maid" MouseLeftButtonUp="OutfitCard_Click">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="☕" FontSize="35" HorizontalAlignment="Center"/>
                                <TextBlock Text="Hầu Gái" FontSize="14" FontWeight="Bold" Foreground="#2F3273" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource OutfitCardStyle}" Width="110" Height="130" Margin="10" Tag="school" MouseLeftButtonUp="OutfitCard_Click">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="🎒" FontSize="35" HorizontalAlignment="Center"/>
                                <TextBlock Text="Học Sinh" FontSize="14" FontWeight="Bold" Foreground="#2F3273" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource OutfitCardStyle}" Width="110" Height="130" Margin="10" Tag="sleeping" MouseLeftButtonUp="OutfitCard_Click">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="💤" FontSize="35" HorizontalAlignment="Center"/>
                                <TextBlock Text="Đồ Ngủ" FontSize="14" FontWeight="Bold" Foreground="#2F3273" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource OutfitCardStyle}" Width="110" Height="130" Margin="10" Tag="winter" MouseLeftButtonUp="OutfitCard_Click">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="🧣" FontSize="35" HorizontalAlignment="Center"/>
                                <TextBlock Text="Mùa Đông" FontSize="14" FontWeight="Bold" Foreground="#2F3273" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>
                    </WrapPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</Window>