<Window x:Class="AstraCosmeris_.TutorialBoardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AstraCosmeris_" 
        Title="Hướng dẫn Khởi động" Height="auto" Width="320" SizeToContent="Height"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowActivated="False" Focusable="False">

    <Window.Resources>
        <local:BoolToCheckConverter x:Key="BoolToCheckConverter"/>
        <local:BoolToInvisConverter x:Key="BoolToInvisConverter"/>

        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>
    </Window.Resources>

    <Grid Margin="25">
        <Border CornerRadius="16" MouseLeftButtonDown="Border_MouseLeftButtonDown">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FBFAFF" Offset="0.0"/>
                    <GradientStop Color="#EEF2F9" Offset="1.0"/>
                </LinearGradientBrush>
            </Border.Background>

            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#9FB2D4" Offset="0.0"/>
                    <GradientStop Color="#2F3273" Offset="1.0"/>
                </LinearGradientBrush>
            </Border.BorderBrush>
            <Border.BorderThickness>
                <Thickness>1.5</Thickness>
            </Border.BorderThickness>

            <Border.Effect>
                <DropShadowEffect BlurRadius="20" Opacity="0.15" ShadowDepth="8" Direction="270" Color="#2F3273"/>
            </Border.Effect>

            <StackPanel Margin="18,20,18,20">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
                    <TextBlock Text="⚙️" FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="HƯỚNG DẪN KHỞI ĐỘNG" FontWeight="Bold" FontSize="14" Foreground="#2F3273" VerticalAlignment="Center"/>
                </StackPanel>

                <Rectangle Height="1" Fill="#D0D9E8" Margin="0,0,0,15"/>

                <ItemsControl x:Name="LvQuests">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="Transparent" Margin="0,6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="30"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="30"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="{Binding IsCompleted, Converter={StaticResource BoolToCheckConverter}}" 
                                               FontFamily="Segoe UI Emoji" FontSize="15" VerticalAlignment="Top" Margin="0,2,0,0"/>

                                    <TextBlock Grid.Column="1" Text="{Binding Title}" TextWrapping="Wrap" FontSize="13" 
                                               Foreground="#333333" LineHeight="18"
                                               TextDecorations="{Binding TextDecoration}" Opacity="{Binding Opacity}" VerticalAlignment="Center"/>

                                    <Button Grid.Column="2" Content="❔" Background="#E8EDF5" Foreground="#2F3273" 
                                            BorderThickness="0" Cursor="Hand" Width="22" Height="22" 
                                            Tag="{Binding Id}" Click="BtnHint_Click" ToolTip="Nhấn để xem gợi ý"
                                            Visibility="{Binding IsCompleted, Converter={StaticResource BoolToInvisConverter}}"
                                            VerticalAlignment="Top" HorizontalAlignment="Right">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="11"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock x:Name="TxtVictory" Text="✨ HOÀN TẤT THIẾT LẬP ✨" FontSize="15" FontWeight="Bold" Foreground="#2F3273" 
                           HorizontalAlignment="Center" Margin="0,20,0,0" Visibility="Collapsed" RenderTransformOrigin="0.5,0.5">
                    <TextBlock.RenderTransform>
                        <ScaleTransform x:Name="VictoryScale" ScaleX="1" ScaleY="1"/>
                    </TextBlock.RenderTransform>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</Window>